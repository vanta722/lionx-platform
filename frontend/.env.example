# Lion X Platform — Environment Variables
# Only ONE contract to deploy: LDAPlatform.sol
# LDA v1 token (TNP1D18nJCqQHhv4i38qiNtUUuL5VyNoC1) is used directly — no migration needed

# ── Platform Contract (update after mainnet deploy) ──
NEXT_PUBLIC_PLATFORM=your_platform_contract_address_here

# ── Treasury wallet (receives 30% of all query burns) ──
NEXT_PUBLIC_TREASURY=your_treasury_wallet_address_here

# ── AI API (server-side only — NEVER use NEXT_PUBLIC_ prefix) ──
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Tronscan API (server-side only — prevents unauthenticated rate limits) ──
TRONSCAN_API_KEY=your_tronscan_api_key_here

# ── MLB Picks tool (get free key at https://the-odds-api.com) ──
ODDS_API_KEY=get_free_key_at_the-odds-api.com

# ── OpenAI (used by MLB Picks for AI pick generation) ──
OPENAI_API_KEY=your_openai_api_key_here

# ── Upstash KV (REQUIRED for serverless replay/rate-limit protection) ──
KV_REST_API_URL=your_upstash_kv_url_here
KV_REST_API_TOKEN=your_upstash_kv_token_here

# ── Mainnet Deploy Command ──
# tronbox migrate --network mainnet --f 3 --to 3
