# Lion X Platform — Environment Variables
# Copy to .env.local and fill in values
#
# MAINNET DEPLOY CHECKLIST:
# 1. Deploy contracts: tronbox migrate --network mainnet --reset --f 1
# 2. Copy contract addresses from deployment output
# 3. Update all NEXT_PUBLIC_* below with mainnet addresses
# 4. Set NEXT_PUBLIC_TREASURY to your treasury wallet address
# 5. Redeploy Vercel frontend

# ── Contract Addresses ──────────────────────────────────────
# Shasta testnet (current)
NEXT_PUBLIC_LDA_V1=TNP1D18nJCqQHhv4i38qiNtUUuL5VyNoC1
NEXT_PUBLIC_LDA_V2=TURQgDcWWeg633Azz8SMrDrHHYdgM3Nfxi
NEXT_PUBLIC_MIGRATION=TBJewkqJqCRqurLMiTnqYkRhVxYWeHvrVP
NEXT_PUBLIC_PLATFORM=TYKu4AJv6cqNwoyZtnjzpsyE9Tf5WkLQhh

# Treasury wallet (receives 30% of all burns)
NEXT_PUBLIC_TREASURY=your_treasury_wallet_address_here

# ── AI API (server-side only — NEVER prefix with NEXT_PUBLIC_) ──
OPENROUTER_API_KEY=your_openrouter_key_here
