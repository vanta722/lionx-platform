# ── LDA v2 Deployment Environment Variables ──
# Copy to .env and fill in your values
# NEVER commit .env to git

# Your Tron wallet private key (no 0x prefix)
TRON_PRIVATE_KEY=your_private_key_here

# Treasury wallet address (receives 30% of all burns)
TREASURY_WALLET=your_treasury_wallet_address

# Optional: LDA v1 address on Shasta testnet (if deploying mock v1 for testing)
LDA_V1_SHASTA=TNP1D18nJCqQHhv4i38qiNtUUuL5VyNoC1
